   "source": [
    "# One hot encoding\n",
    "cat_feature = X_price.select_dtypes(include=['object','category'])\n",
    "cat_one_hot = pd.get_dummies(cat_feature)\n",
    "num_feature = X_price.select_dtypes(exclude=['object','category'])\n",
    "X = np.concatenate((cat_one_hot,num_feature), axis = 1)\n",
    "Y = Y_price"
   ]
  },
