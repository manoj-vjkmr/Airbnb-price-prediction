   "source": [
    "# Split data into test and train set\n",
    "X_train, X_val_test, Y_train, Y_val_test = train_test_split(X,Y, test_size = 0.4, random_state = 46)\n",
    "X_val, X_test, Y_val, Y_test = train_test_split(X_val_test, Y_val_test, test_size = 0.5, random_state = 46)\n",
    "print(X_train.shape) ; print(X_val.shape); print(X_test.shape); print(Y_train.shape); print(Y_val.shape); print(Y_test.shape)"
