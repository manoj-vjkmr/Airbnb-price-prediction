   "source": [
    "airbnb_part['price'] = np.log(airbnb_part['price']+1)\n",
    "X_price = airbnb_part[['neighbourhood_group', 'room_type', 'minimum_nights', 'availability_365', 'calculated_host_listings_count', 'number_of_reviews']]\n",
